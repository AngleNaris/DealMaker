{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DealMaker",
  "version": "2.0.0",
  "identifier": "com.dealmaker.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DealMaker",
        "width": 1100,
        "height": 800,
        "minWidth": 900,
        "minHeight": 650
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
